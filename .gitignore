// Next.js + Firebase Mobile-First Fitness App - Full Setup for Netlify with Plugin

import { useState } from 'react'; import Head from 'next/head';

export default function Home() { const [darkMode, setDarkMode] = useState(false); const [language, setLanguage] = useState('en'); const [showScan, setShowScan] = useState(false); const [formData, setFormData] = useState({ age: '', height: '', weight: '', activity: 'medium' }); const [result, setResult] = useState(null);

const handleInputChange = (e) => { const { name, value } = e.target; setFormData({ ...formData, [name]: value }); };

const calculateBodyType = () => { const { age, height, weight, activity } = formData; let bodyType = 'Ectomorph'; if(weight/height > 0.5) bodyType = 'Endomorph'; else if(weight/height > 0.35) bodyType = 'Mesomorph';

const muscleMass = Math.round(weight * 0.4);
const fatMass = Math.round(weight * 0.2);
const calories = Math.round(2000 + (activity === 'high' ? 500 : activity === 'medium' ? 250 : 0));
const protein = Math.round(weight * 2);
const carbs = Math.round(weight * 3);
const sugar = Math.round(carbs * 0.1);

setResult({ bodyType, muscleMass, fatMass, calories, protein, carbs, sugar });

};

return ( <div className={darkMode ? 'bg-gray-900 text-white' : 'bg-white text-black'}> <Head> <title>Your Way to Your Dream Body</title> </Head>

{/* Header */}
  <header className="flex justify-between p-4">
    <button onClick={() => setDarkMode(!darkMode)} className="text-xl">{darkMode ? '🌙' : '☀️'}</button>
    <select value={language} onChange={(e) => setLanguage(e.target.value)} className="border rounded px-2">
      <option value="en">English</option>
      <option value="ar">Arabic</option>
      <option value="fr">French</option>
      <option value="jp">Japanese</option>
      <option value="cn">Chinese</option>
    </select>
  </header>

  {/* Welcome */}
  <main className="p-4 text-center">
    <h1 className="text-2xl font-bold mb-6">Welcome here Champ, let's start cooking 🔥</h1>
    <button onClick={() => setShowScan(true)} className="bg-blue-500 text-white px-6 py-3 rounded-lg font-bold">Scan Your Body Type</button>
  </main>

  {/* Body Scan Form */}
  {showScan && (
    <div className="p-4">
      <input type="number" name="age" placeholder="Age" className="border p-2 rounded w-full mb-2" onChange={handleInputChange} />
      <input type="number" name="height" placeholder="Height (cm)" className="border p-2 rounded w-full mb-2" onChange={handleInputChange} />
      <input type="number" name="weight" placeholder="Weight (kg)" className="border p-2 rounded w-full mb-2" onChange={handleInputChange} />
      <select name="activity" className="border p-2 rounded w-full mb-2" onChange={handleInputChange}>
        <option value="low">Low</option>
        <option value="medium">Medium</option>
        <option value="high">Athletic</option>
        <option value="veryHigh">Very High</option>
      </select>
      <button onClick={calculateBodyType} className="bg-green-500 text-white px-6 py-3 rounded-lg font-bold w-full">Start</button>
    </div>
  )}

  {/* Results */}
  {result && (
    <div className="p-4 mt-4 border-t">
      <h2 className="text-xl font-bold mb-2">Your Body Analysis</h2>
      <p>Body Type: {result.bodyType}</p>
      <p>Muscle Mass: {result.muscleMass} kg</p>
      <p>Fat Mass: {result.fatMass} kg</p>
      <p>Calories: {result.calories} kcal/day</p>
      <p>Protein: {result.protein} g/day</p>
      <p>Carbs: {result.carbs} g/day</p>
      <p>Sugar: {result.sugar} g/day</p>

      <h3 className="text-lg font-bold mt-4 mb-2">Choose Your Goal</h3>
      <div className="flex flex-col gap-2">
        <button className="bg-red-500 text-white px-4 py-2 rounded">Bulking Plan</button>
        <button className="bg-yellow-500 text-white px-4 py-2 rounded">Cutting Plan</button>
        <button className="bg-blue-500 text-white px-4 py-2 rounded">Fitness Plan</button>
      </div>
    </div>
  )}
</div>

); }
